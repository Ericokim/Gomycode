{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "angular-benchmark": {
      "projectType": "application",
      "root": "apps/angular",
      "sourceRoot": "apps/angular/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/angular",
            "index": "apps/angular/src/index.html",
            "browser": "apps/angular/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/angular/tsconfig.app.json",
            "styles": ["shared/styles.css"]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": false
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "angular-benchmark:build:production"
            },
            "development": {
              "buildTarget": "angular-benchmark:build:development"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 5176
          }
        }
      }
    }
  }
}
